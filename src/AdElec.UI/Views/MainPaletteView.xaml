<UserControl x:Class="AdElec.UI.Views.MainPaletteView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="280"
             Background="#2D2D2D">

    <UserControl.Resources>
        <!-- Botón primario oscuro -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#444"/>
                                <Setter Property="Foreground" Value="#888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botón secundario gris -->
        <Style x:Key="BtnSecondary" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
            <Setter Property="Background" Value="#444"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#555"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Botón acción verde -->
        <Style x:Key="BtnAction" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
            <Setter Property="Background" Value="#2E7D32"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1B5E20"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#444"/>
                    <Setter Property="Foreground" Value="#888"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Label de sección -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- Valor numérico -->
        <Style x:Key="ValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Input de texto oscuro -->
        <Style x:Key="DarkInput" TargetType="TextBox">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>

        <!-- ComboBox oscuro -->
        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5,4"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <BooleanToVisibilityConverter x:Key="BoolVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="Auto"/>  <!-- Tablero selector -->
            <RowDefinition Height="Auto"/>  <!-- Nuevo tablero form -->
            <RowDefinition Height="Auto"/>  <!-- Info AEA -->
            <RowDefinition Height="*"/>     <!-- Circuitos DataGrid -->
            <RowDefinition Height="Auto"/>  <!-- Acciones -->
            <RowDefinition Height="Auto"/>  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#1A1A1A" Padding="10,8">
            <Grid>
                <TextBlock Text="AD-ELEC" Foreground="White"
                           FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="⟳" Style="{StaticResource BtnSecondary}"
                            Padding="6,3" FontSize="11"
                            Command="{Binding CheckMotorCommand}"
                            ToolTip="Verificar conexión con AEA-MOTOR"/>
                    <TextBlock Text="{Binding MotorStatusText}"
                               Foreground="{Binding MotorStatusColor}"
                               FontSize="11" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ SELECTOR DE TABLERO ══════════════════════════════════════ -->
        <Border Grid.Row="1" Background="#252525" Padding="10,8">
            <StackPanel>
                <TextBlock Text="Tablero" Style="{StaticResource SectionLabel}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0"
                              Style="{StaticResource DarkCombo}"
                              ItemsSource="{Binding Panels}"
                              SelectedItem="{Binding SelectedPanel, Mode=TwoWay}"
                              DisplayMemberPath="Name"
                              Margin="0,0,6,0"/>
                    <Button Grid.Column="1" Content="+ Nuevo"
                            Style="{StaticResource BtnSecondary}"
                            Command="{Binding NuevoTableroCommand}"
                            Padding="8,4"/>
                </Grid>

                <!-- Info del tablero seleccionado -->
                <StackPanel Orientation="Horizontal" Margin="0,5,0,0"
                            Visibility="{Binding HasPanel, Converter={StaticResource BoolVis}}">
                    <TextBlock Foreground="#AAAAAA" FontSize="11"
                               Text="{Binding SelectedPanel.Location, StringFormat='{}📍 {0}'}"/>
                    <TextBlock Foreground="#AAAAAA" FontSize="11" Margin="8,0,0,0"
                               Text="{Binding SelectedPanel.PhaseCount, StringFormat='{}⚡ {0}F'}"/>
                    <TextBlock Foreground="#AAAAAA" FontSize="11" Margin="8,0,0,0"
                               Text="{Binding SelectedPanel.MainBreakerAmps, StringFormat='{}{0}A'}"/>
                    <TextBlock Foreground="#AAAAAA" FontSize="11" Margin="8,0,0,0"
                               Text="{Binding SelectedPanel.SuperficieCubiertaM2, StringFormat='{}{0}m²'}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ═══ FORMULARIO NUEVO TABLERO (colapsable) ════════════════════ -->
        <Border Grid.Row="2" Background="#1E3A52" Padding="10,8"
                Visibility="{Binding ShowNewPanelForm, Converter={StaticResource BoolVis}}">
            <StackPanel>
                <TextBlock Text="Nuevo Tablero" Style="{StaticResource SectionLabel}" Foreground="#64B5F6"/>
                <TextBlock Text="Nombre" Foreground="#AAAAAA" FontSize="11" Margin="0,0,0,2"/>
                <TextBox Style="{StaticResource DarkInput}" Margin="0,0,0,6"
                         Text="{Binding NewPanelName, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Text="Ubicación" Foreground="#AAAAAA" FontSize="11" Margin="0,0,0,2"/>
                <TextBox Style="{StaticResource DarkInput}" Margin="0,0,0,6"
                         Text="{Binding NewPanelLocation, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Text="Superficie cubierta (m²)" Foreground="#AAAAAA" FontSize="11" Margin="0,0,0,2"/>
                <TextBox Style="{StaticResource DarkInput}" Margin="0,0,0,6"
                         Text="{Binding NewPanelSuperficie, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Text="Fases" Foreground="#AAAAAA" FontSize="11" Margin="0,0,0,2"/>
                <ComboBox Style="{StaticResource DarkCombo}" Margin="0,0,0,6"
                          SelectedValue="{Binding NewPanelPhaseCount, Mode=TwoWay}"
                          SelectedValuePath="Tag">
                    <ComboBoxItem Content="Monofásico (1F)" Tag="1" IsSelected="True"/>
                    <ComboBoxItem Content="Trifásico (3F)" Tag="3"/>
                </ComboBox>
                <TextBlock Text="Tipo de tablero" Foreground="#AAAAAA" FontSize="11" Margin="0,0,0,2"/>
                <ComboBox Style="{StaticResource DarkCombo}" Margin="0,0,0,8"
                          SelectedValue="{Binding NewPanelTipo, Mode=TwoWay}"
                          SelectedValuePath="Tag">
                    <ComboBoxItem Content="Tablero Seccional"      Tag="Tablero Seccional" IsSelected="True"/>
                    <ComboBoxItem Content="Tablero Principal"       Tag="Tablero Principal"/>
                    <ComboBoxItem Content="Tablero Seccional Chico" Tag="Tablero Seccional Chico"/>
                </ComboBox>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancelar" Style="{StaticResource BtnSecondary}"
                            Command="{Binding CancelarNuevoTableroCommand}" Margin="0,0,6,0"/>
                    <Button Content="Guardar" Style="{StaticResource BtnPrimary}"
                            Command="{Binding ConfirmarNuevoTableroCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ═══ RESUMEN AEA ═══════════════════════════════════════════════ -->
        <Border Grid.Row="3" Background="#252525" Padding="10,6"
                Visibility="{Binding HasPanel, Converter={StaticResource BoolVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Carga Total" Style="{StaticResource SectionLabel}"/>
                    <TextBlock Style="{StaticResource ValueText}"
                               Text="{Binding TotalLoadKVA, StringFormat='{}{0} kVA'}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="Grado" Style="{StaticResource SectionLabel}"/>
                    <TextBlock Style="{StaticResource ValueText}"
                               Text="{Binding LastGrado, FallbackValue='—'}"/>
                </StackPanel>
                <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                    <TextBlock Text="Norma" Style="{StaticResource SectionLabel}"/>
                    <TextBlock Text="{Binding CumpleNormaText, FallbackValue='—'}"
                               Foreground="{Binding CumpleNormaColor}"
                               FontSize="12" FontWeight="SemiBold"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ CIRCUITOS ══════════════════════════════════════════════════ -->
        <Border Grid.Row="4" Background="#2D2D2D" Padding="10,8">
            <StackPanel>
                <TextBlock Text="Circuitos" Style="{StaticResource SectionLabel}"/>
                <DataGrid ItemsSource="{Binding Circuits}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserResizeRows="False"
                          CanUserAddRows="False"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          Background="#1A1A1A"
                          RowBackground="#222"
                          AlternatingRowBackground="#282828"
                          Foreground="White"
                          BorderBrush="#444"
                          BorderThickness="1"
                          FontSize="11"
                          MaxHeight="220">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#1A1A1A"/>
                            <Setter Property="Foreground" Value="#AAAAAA"/>
                            <Setter Property="FontSize" Value="10"/>
                            <Setter Property="Padding" Value="5,4"/>
                            <Setter Property="BorderBrush" Value="#333"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Nombre" Binding="{Binding Name}" Width="60"/>
                        <DataGridTextColumn Header="Tipo"   Binding="{Binding Type}" Width="45"/>
                        <DataGridTextColumn Header="mm²"   Binding="{Binding WireSectionMm2}" Width="38"/>
                        <DataGridTextColumn Header="VA"    Binding="{Binding LoadVA, StringFormat=N0}" Width="50"/>
                        <DataGridTextColumn Header="A"     Binding="{Binding BreakerAmps}" Width="35"/>
                        <DataGridTextColumn Header="Fase"  Binding="{Binding Phase}" Width="35"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Placeholder cuando no hay tablero -->
                <TextBlock Text="Seleccioná un tablero para ver sus circuitos."
                           Foreground="#666" FontSize="11" TextAlignment="Center"
                           Margin="0,20"
                           Visibility="{Binding HasPanel, Converter={StaticResource BoolVis}}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasPanel}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ═══ ACCIONES ══════════════════════════════════════════════════ -->
        <Border Grid.Row="5" Background="#1A1A1A" Padding="10,8">
            <StackPanel>
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Content="Calcular AEA 90364"
                            Style="{StaticResource BtnPrimary}"
                            Command="{Binding CalcularAeaCommand}"
                            ToolTip="Envía los circuitos al motor AEA-MOTOR y calcula secciones, caída de tensión y cumplimiento normativo."/>
                    <Button Grid.Column="2"
                            Content="↺ DWG"
                            Style="{StaticResource BtnSecondary}"
                            Command="{Binding RecargarCircuitosCommand}"
                            Padding="8,5"
                            ToolTip="Escanea los bloques del dibujo con D=tablero y recarga los circuitos (ADE_RECARGAR)."/>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Luminarias"
                            Style="{StaticResource BtnAction}"
                            Command="{Binding SugerirLuminariasCommand}"
                            ToolTip="Ejecuta ADE_LUMINARIAS en el dibujo activo."/>
                    <Button Grid.Column="2" Content="Tomas"
                            Style="{StaticResource BtnAction}"
                            Command="{Binding SugerirTomasCommand}"
                            ToolTip="Ejecuta ADE_TOMAS en el dibujo activo."/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ═══ STATUS BAR ════════════════════════════════════════════════ -->
        <Border Grid.Row="6" Background="#111" Padding="10,4">
            <Grid>
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="#888" FontSize="10"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center"/>
                <!-- Indicador de ocupado -->
                <TextBlock Text="Calculando..." Foreground="#64B5F6" FontSize="10"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           Visibility="{Binding IsBusy, Converter={StaticResource BoolVis}}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
